# ==============================================================================
# AI Stock Advisor - Environment Variables Configuration Template
# Copy this file to .env and replace placeholders with your actual keys.
# DO NOT commit the .env file containing secrets to version control.
# ==============================================================================

# Core Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# LLM Integration Settings
# Allowed values: gemini, openai
LLM_PROVIDER=gemini

# API Keys (Replace with your actual keys)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Market Data Service
MARKET_DATA_PROVIDER=yfinance
MARKET_DATA_API_KEY=dummy_key_not_required_for_yfinance

# Optional: Port configuration if running API/Web interface in the future
APP_PORT=8000
APP_HOST=127.0.0.1

# Telegram Bot Configurations (For Pre-Market Reports & Commands)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_or_channel_id_here
